[Unit]
Description=Vibedeck FastAPI backend (uvicorn)
After=network-online.target docker.service
Wants=network-online.target
# DB runs in Docker container vibedeck_db; Restart=always covers brief DB unavailability at boot.

[Service]
Type=simple
User=chronos
WorkingDirectory=/home/chronos/sites/vibedeck/backend
ExecStart=/home/chronos/sites/vibedeck/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8100
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
