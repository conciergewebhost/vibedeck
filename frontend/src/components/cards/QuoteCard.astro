---
/** QuoteCard — pull quote, styled distinctively. Attribution optional. */
interface Props { html: string; }
const { html } = Astro.props;
---
<div class="card-body card-body--quote" set:html={html} />

<style>
  .card-body--quote :global(blockquote) {
    margin: 0;
    border-left: 3px solid var(--vd-accent);
    padding-left: 1.25rem;
    font-size: clamp(1.25rem, 4vw, 1.75rem);
    line-height: 1.4;
    color: var(--vd-heading);
    font-style: italic;
  }
</style>
