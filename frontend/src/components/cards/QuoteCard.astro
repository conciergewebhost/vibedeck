---
/**
 * QuoteCard — pull quote, styled distinctively. Attribution optional.
 * STUB: renders raw body; real markdown rendering + styling pending.
 */
interface Props { meta: Record<string, unknown>; body: string; }
const { body } = Astro.props;
---
<section class="card card--quote" set:html={body} />

<style>
  .card--quote { padding: var(--vd-card-padding); }
</style>
