---
/** GraphicCard — full-bleed image/chart with a small caption beneath. */
interface Props { html: string; }
const { html } = Astro.props;
---
<div class="card-body card-body--graphic" data-card-type="graphic" set:html={html} />

<style>
  .card-body--graphic {
    text-align: center;
  }
  .card-body--graphic :global(img) {
    border-radius: var(--vd-radius);
    margin-inline: auto;
  }
  /* The paragraph following the image acts as the caption. */
  .card-body--graphic :global(em) {
    display: block;
    margin-top: 0.75rem;
    color: var(--vd-text-muted);
    font-size: 0.9rem;
  }
</style>
