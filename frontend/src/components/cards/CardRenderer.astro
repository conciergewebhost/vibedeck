---
/**
 * CardRenderer — maps a parsed card's `type` to its component and renders
 * the card's markdown body to HTML once, here. Adding a card type touches
 * exactly this switchboard plus a new component file.
 */
import TitleCard from "./TitleCard.astro";
import ConceptCard from "./ConceptCard.astro";
import SummaryCard from "./SummaryCard.astro";
import GraphicCard from "./GraphicCard.astro";
import QuoteCard from "./QuoteCard.astro";
import { renderMarkdown } from "../../lib/markdown";
import type { Card } from "../../lib/api";

interface Props {
  card: Card;
}

const { card } = Astro.props;

const REGISTRY: Record<string, any> = {
  title: TitleCard,
  concept: ConceptCard,
  summary: SummaryCard,
  graphic: GraphicCard,
  quote: QuoteCard,
};

// Unknown types should never reach here (the parser validates), but fall
// back to the concept treatment rather than rendering nothing.
const Component = REGISTRY[card.type] ?? ConceptCard;
const html = renderMarkdown(card.body);
---

<Component html={html} />
