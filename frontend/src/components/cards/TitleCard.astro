---
/** TitleCard — deck opening card, large centred display treatment. */
interface Props { html: string; }
const { html } = Astro.props;
---
<div class="card-body card-body--title" data-card-type="title" set:html={html} />

<style>
  .card-body--title {
    text-align: center;
  }
  .card-body--title :global(h1) {
    font-size: clamp(2.25rem, 9vw, 4rem);
    letter-spacing: -0.03em;
    margin: 0 0 0.5rem;
    background: linear-gradient(90deg, var(--vd-accent), var(--vd-accent-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .card-body--title :global(h3) {
    color: var(--vd-text-muted);
    font-weight: 400;
  }
</style>
