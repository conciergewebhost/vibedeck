---
/**
 * ConceptCard — a single idea, explained cleanly. The constraint is the feature.
 * STUB: renders raw body; real markdown rendering + styling pending.
 */
interface Props { meta: Record<string, unknown>; body: string; }
const { body } = Astro.props;
---
<section class="card card--concept" set:html={body} />

<style>
  .card--concept { padding: var(--vd-card-padding); }
</style>
