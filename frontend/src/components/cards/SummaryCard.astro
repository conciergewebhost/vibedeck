---
/** SummaryCard — big-picture consolidation, bullet points. */
interface Props { html: string; }
const { html } = Astro.props;
---
<div class="card-body card-body--summary" set:html={html} />

<style>
  .card-body--summary :global(ul) {
    line-height: 2;
  }
  .card-body--summary :global(li) {
    margin-bottom: 0.25rem;
  }
</style>
