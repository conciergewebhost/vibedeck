---
/**
 * SummaryCard — big-picture consolidation, bullet points, palette cleanser.
 * STUB: renders raw body; real markdown rendering + styling pending.
 */
interface Props { meta: Record<string, unknown>; body: string; }
const { body } = Astro.props;
---
<section class="card card--summary" set:html={body} />

<style>
  .card--summary { padding: var(--vd-card-padding); }
</style>
