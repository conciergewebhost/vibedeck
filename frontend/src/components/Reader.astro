---
/**
 * Reader — the paginated card viewport.
 *
 * Renders every card into the DOM (first one active) and a small client
 * script drives navigation: prev/next buttons, keyboard arrows, touch
 * swipe, a "Page n of total" indicator, and an index modal that lists all
 * cards for direct jumping. Framework-free: progressive enhancement on top
 * of server-rendered HTML, so the first card is readable without JS.
 */
import CardRenderer from "./cards/CardRenderer.astro";
import { cardLabel } from "../lib/markdown";
import type { DeckDetail } from "../lib/api";

interface Props {
  deck: DeckDetail;
  topicSlug: string;
  // Embed mode (e.g. the portal thumbnail): show only the first card, no nav
  // chrome, no index modal, and no client interactions.
  embed?: boolean;
}

const { deck, embed = false } = Astro.props;
const total = deck.cards.length;
---

<section
  class="reader"
  aria-roledescription="card deck"
  data-embed={embed ? "" : undefined}
  data-transition={deck.transition ?? "slide"}
  data-reveal={deck.reveal_bullets ? "" : undefined}
>
  <div class="reader__stage">
    {
      deck.cards.map((card, i) => (
        <article
          class:list={["reader__card", { "is-active": i === 0 }]}
          data-index={i}
          aria-hidden={i === 0 ? "false" : "true"}
        >
          <CardRenderer card={card} />
        </article>
      ))
    }
  </div>

  {
    !embed && (
      <nav class="reader__nav" aria-label="Card navigation">
        <button class="reader__btn" data-nav="prev" aria-label="Previous card">‹</button>
        <span class="reader__progress">
          <span data-current>1</span> / {total}
        </span>
        <button class="reader__btn" data-nav="next" aria-label="Next card">›</button>
        <button class="reader__btn reader__btn--index" data-nav="index" aria-label="Open index">☰</button>
      </nav>
    )
  }

  {
    !embed && (
      <div class="reader__modal" data-modal hidden>
        <div class="reader__modal-panel" role="dialog" aria-label="Card index">
          <header class="reader__modal-head">
            <button class="reader__btn" data-nav="close" aria-label="Close index">✕</button>
          </header>
          <ol class="reader__index">
            {deck.cards.map((card, i) => (
              <li>
                <button data-jump={i}>
                  <span class="reader__index-num">{i + 1}</span>
                  <span class="reader__index-label">{cardLabel(card.body, card.type)}</span>
                </button>
              </li>
            ))}
          </ol>
        </div>
      </div>
    )
  }
</section>

<script>
  function initReader() {
    const reader = document.querySelector<HTMLElement>(".reader");
    if (!reader) return;
    // Embed mode (thumbnail): static first card, no interactions.
    if (reader.hasAttribute("data-embed")) return;
    const cards = Array.from(
      reader.querySelectorAll<HTMLElement>(".reader__card"),
    );
    const total = cards.length;
    const currentEl = reader.querySelector<HTMLElement>("[data-current]");
    const modal = reader.querySelector<HTMLElement>("[data-modal]");
    let idx = 0;

    // ── Author-controlled behavior (deck frontmatter, threaded via the
    //    API): card-change transition + progressive bullet reveal. Both
    //    respect prefers-reduced-motion; SSR renders bullets visible, so
    //    no-JS readers and embed thumbnails always see full content.
    const transition = reader.dataset.transition ?? "slide";
    const revealMode = reader.hasAttribute("data-reveal");
    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    // Per-card bullet lists + how many reveal steps are currently shown.
    // The count persists, so returning to a half-read card resumes where
    // it was.
    const bullets: HTMLElement[][] = cards.map((c) =>
      revealMode ? Array.from(c.querySelectorAll<HTMLElement>("li")) : [],
    );
    // Content after a card's last bullet list is gated behind the bullets:
    // hidden until every bullet is shown, then revealed by one further
    // advance — so the final bullet still lands on its own.
    const trailing: HTMLElement[][] = cards.map((c, i) => {
      if (bullets[i].length === 0) return [];
      const body = c.querySelector<HTMLElement>(".card-body");
      if (!body) return [];
      const kids = Array.from(body.children) as HTMLElement[];
      const lastList = kids.reduce(
        (last, el, n) => (el.matches("ul, ol") ? n : last),
        -1,
      );
      return lastList === -1 ? [] : kids.slice(lastList + 1);
    });
    // Reveal steps per card: one per bullet, plus one for a trailing block.
    const steps = (i: number) =>
      bullets[i].length + (trailing[i].length ? 1 : 0);
    const revealed: number[] = cards.map(() => 0);

    function applyReveal(i: number) {
      bullets[i].forEach((li, n) =>
        li.classList.toggle("vd-li-hidden", n >= revealed[i]),
      );
      const showTrailing = revealed[i] > bullets[i].length;
      trailing[i].forEach((el) =>
        el.classList.toggle("vd-li-hidden", !showTrailing),
      );
    }
    function revealAll(i: number) {
      revealed[i] = steps(i);
      applyReveal(i);
    }
    if (revealMode) cards.forEach((_, i) => applyReveal(i));

    function animateIn(card: HTMLElement, dir: number) {
      if (reduceMotion || transition === "none" || dir === 0) return;
      const frames =
        transition === "fade"
          ? [{ opacity: 0 }, { opacity: 1 }]
          : [
              { opacity: 0, transform: `translateX(${24 * dir}px)` },
              { opacity: 1, transform: "translateX(0)" },
            ];
      card.animate(frames, { duration: 200, easing: "ease-out" });
    }

    function show(n: number, opts: { dir?: number; full?: boolean } = {}) {
      const target = Math.max(0, Math.min(total - 1, n));
      const dir = opts.dir ?? Math.sign(target - idx);
      const moved = target !== idx;
      idx = target;
      if (revealMode) {
        if (opts.full) revealAll(idx);
        else applyReveal(idx);
      }
      cards.forEach((c, i) => {
        const active = i === idx;
        c.classList.toggle("is-active", active);
        c.setAttribute("aria-hidden", active ? "false" : "true");
      });
      if (moved) animateIn(cards[idx], dir);
      if (currentEl) currentEl.textContent = String(idx + 1);
    }

    // next: with reveal on, surface the card's next reveal step first (a
    // bullet, or finally the post-bullets content); advance to the next
    // card only once everything on this one is shown.
    function next() {
      if (revealMode && revealed[idx] < steps(idx)) {
        revealed[idx] += 1;
        const fresh =
          revealed[idx] <= bullets[idx].length
            ? [bullets[idx][revealed[idx] - 1]]
            : trailing[idx];
        applyReveal(idx);
        if (!reduceMotion && transition !== "none")
          fresh.forEach((el) =>
            el.animate([{ opacity: 0 }, { opacity: 1 }], {
              duration: 150,
              easing: "ease-out",
            }),
          );
        return;
      }
      show(idx + 1, { dir: 1 });
    }
    // prev/jump: direct access — arrive with the card fully revealed.
    const prev = () => show(idx - 1, { dir: -1, full: true });
    const jump = (n: number) => show(n, { full: true });

    const openModal = () => modal?.removeAttribute("hidden");
    const closeModal = () => modal?.setAttribute("hidden", "");

    reader.querySelectorAll<HTMLElement>("[data-nav]").forEach((btn) => {
      btn.addEventListener("click", () => {
        switch (btn.dataset.nav) {
          case "next": next(); break;
          case "prev": prev(); break;
          case "index": openModal(); break;
          case "close": closeModal(); break;
        }
      });
    });

    reader.querySelectorAll<HTMLElement>("[data-jump]").forEach((btn) => {
      btn.addEventListener("click", () => {
        jump(Number(btn.dataset.jump));
        closeModal();
      });
    });

    // Dismiss the modal when tapping the backdrop.
    modal?.addEventListener("click", (e) => {
      if (e.target === modal) closeModal();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "ArrowRight") next();
      else if (e.key === "ArrowLeft") prev();
      else if (e.key === "Escape") closeModal();
    });

    // Touch swipe (horizontal).
    let startX: number | null = null;
    reader.addEventListener(
      "touchstart",
      (e) => { startX = e.changedTouches[0].clientX; },
      { passive: true },
    );
    reader.addEventListener(
      "touchend",
      (e) => {
        if (startX === null) return;
        const dx = e.changedTouches[0].clientX - startX;
        if (Math.abs(dx) > 40) (dx < 0 ? next() : prev());
        startX = null;
      },
      { passive: true },
    );

    show(0);
  }

  initReader();
</script>

<style>
  .reader {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    background: var(--vd-bg);
  }
  .reader__stage {
    flex: 1;
    display: flex;
    overflow-y: auto;
    overflow-x: hidden; /* never let scaled content spill past the edges */
    padding: clamp(1.25rem, 5vw, 2.5rem);
  }
  .reader__card {
    display: none;
    width: 100%;
    max-width: var(--vd-card-max-width);
  }
  .reader__card.is-active {
    display: block;
    /* Auto margins centre the card when it fits but — unlike align-items/
       justify-content centring — keep the top reachable by scroll when a
       card is taller than the stage. */
    margin: auto;
  }
  /* Progressive reveal (bullets + post-bullet content): hidden-but-laid-out
     so nothing reflows as items appear. Global — the elements live in
     set:html markdown content that scoped styles can't reach. */
  .reader :global(.vd-li-hidden) {
    visibility: hidden;
  }

  .reader__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    padding: 0.75rem 1rem calc(0.75rem + env(safe-area-inset-bottom, 0px));
    background: var(--vd-nav-bg);
    backdrop-filter: blur(8px);
    border-top: 1px solid var(--vd-card-border);
  }
  .reader__btn {
    background: transparent;
    border: 1px solid var(--vd-card-border);
    color: var(--vd-text);
    border-radius: 999px;
    width: 2.75rem;
    height: 2.75rem;
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
  }
  .reader__btn:hover {
    border-color: var(--vd-accent);
    color: var(--vd-accent);
  }
  .reader__btn--index {
    margin-left: auto;
    font-size: 1.1rem;
  }
  .reader__progress {
    color: var(--vd-progress);
    font-variant-numeric: tabular-nums;
    min-width: 4rem;
    text-align: center;
  }

  .reader__modal {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    background: rgba(0, 0, 0, 0.6);
    z-index: 10;
  }
  .reader__modal[hidden] {
    display: none;
  }
  .reader__modal-panel {
    background: var(--vd-card-bg);
    border: 1px solid var(--vd-card-border);
    border-radius: var(--vd-radius) var(--vd-radius) 0 0;
    width: 100%;
    max-width: 32rem;
    max-height: 75vh;
    overflow-y: auto;
    padding: 1rem 1.25rem calc(1.25rem + env(safe-area-inset-bottom, 0px));
  }
  .reader__modal-head {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    margin-bottom: 0.5rem;
  }
  .reader__index {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .reader__index button {
    display: flex;
    gap: 0.75rem;
    align-items: baseline;
    width: 100%;
    text-align: left;
    background: transparent;
    border: 0;
    border-top: 1px solid var(--vd-card-border);
    color: var(--vd-text);
    padding: 0.75rem 0.25rem;
    cursor: pointer;
    font-size: 1rem;
  }
  .reader__index button:hover {
    color: var(--vd-accent);
  }
  .reader__index-num {
    color: var(--vd-text-muted);
    font-variant-numeric: tabular-nums;
  }

  /* Desktop: centre the index modal rather than sheet-from-bottom. */
  @media (min-width: 48rem) {
    .reader__modal {
      align-items: center;
    }
    .reader__modal-panel {
      border-radius: var(--vd-radius);
    }
  }
</style>
