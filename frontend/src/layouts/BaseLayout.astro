---
/**
 * BaseLayout — shared document shell.
 *
 * Loads the global base styles and the theme stylesheet selected per
 * deck/topic. `theme` maps to a file in styles/themes/; it defaults to the
 * site-wide default. Also renders the dark/light mode toggle (the
 * operazione theme ships both palettes). Content projects through <slot/>.
 */
import "../styles/global.css";
import NavBar from "../components/NavBar.astro";

// Theme stylesheets live in src/styles/themes/ (CLAUDE.md convention) and
// are selected at runtime by the deck/topic `theme` field. We resolve each
// theme NAME to its bundled, content-hashed URL via Vite's glob import, so
// themes stay in src/ (bundled + cache-busted) instead of being relocated
// to public/. Adding a theme = dropping a new file in styles/themes/.
const themeUrls = import.meta.glob("../styles/themes/*.css", {
  query: "?url",
  import: "default",
  eager: true,
}) as Record<string, string>;

interface Props {
  title: string;
  theme?: string;
  // Show the sitewide navbar. On by default for every page; the immersive
  // reader opts out so it stays full-viewport.
  showNav?: boolean;
  // Social/SEO description and OG card image (brand default).
  description?: string;
  ogImage?: string;
}

// Site-wide default theme. Pages/decks may override via the `theme` prop.
const {
  title,
  theme = "operazione-stile",
  showNav = true,
  description = "Vibedeck turns your markdown files into beautiful, paginated card decks. Mobile-first. Distraction-free.",
  ogImage = "/og-image.png",
} = Astro.props;

// Resolve the requested theme; fall back to default for an unknown name.
const themeHref =
  themeUrls[`../styles/themes/${theme}.css`] ??
  themeUrls["../styles/themes/default.css"];

// Absolute URLs for social scrapers when the deployment's site URL is known
// (Astro.site, set from PUBLIC_SITE_URL); otherwise fall back to root-relative.
const ogImageUrl = Astro.site ? new URL(ogImage, Astro.site).href : ogImage;
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}

    {/* Brand favicons + app icons (The Reticle). */}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/reticle-mark.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#2E231B" />

    {/* Social / Open Graph + Twitter card. */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {/* Apply the mode before first paint (no flash): a saved choice wins;
        otherwise follow the OS, defaulting to light unless it explicitly
        prefers dark. */}
    <script is:inline>
      (() => {
        try {
          let m = localStorage.getItem("vd-mode");
          if (m !== "light" && m !== "dark") {
            m = window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";
          }
          document.documentElement.dataset.mode = m;
        } catch (e) {
          document.documentElement.dataset.mode = "light";
        }
      })();
    </script>
    {/* Theme stylesheet — one file per theme, sets the --vd-* tokens.
        href is the bundled, hashed URL resolved above (not a raw path). */}
    <link rel="stylesheet" href={themeHref} />
    {/* Optional per-page <head> additions (e.g. a deployment's analytics).
        Pages opt in by passing content with slot="head"; most add nothing. */}
    <slot name="head" />
  </head>
  <body>
    <button
      class="mode-toggle"
      data-mode-toggle
      type="button"
      aria-label="Toggle light or dark mode"
    >
      <span data-mode-icon aria-hidden="true">☾</span>
    </button>

    {showNav && <NavBar />}

    <slot />

    <script>
      function syncToggle() {
        const mode =
          document.documentElement.dataset.mode === "light" ? "light" : "dark";
        const icon = document.querySelector("[data-mode-icon]");
        if (icon) icon.textContent = mode === "light" ? "☀" : "☾";
        document
          .querySelector("[data-mode-toggle]")
          ?.setAttribute("aria-pressed", String(mode === "light"));
      }

      document
        .querySelector("[data-mode-toggle]")
        ?.addEventListener("click", () => {
          const cur =
            document.documentElement.dataset.mode === "light" ? "light" : "dark";
          const next = cur === "light" ? "dark" : "light";
          document.documentElement.dataset.mode = next;
          try {
            localStorage.setItem("vd-mode", next);
          } catch (e) {
            /* storage unavailable — mode still applies for this page */
          }
          syncToggle();
        });

      syncToggle();
    </script>

    <style>
      .mode-toggle {
        position: fixed;
        top: 1rem;
        right: 1rem;
        z-index: 50;
        width: 2.5rem;
        height: 2.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--vd-card-bg);
        color: var(--vd-text);
        border: 1px solid var(--vd-card-border);
        border-radius: 999px;
        font-size: 1.05rem;
        line-height: 1;
        cursor: pointer;
      }
      .mode-toggle:hover {
        border-color: var(--vd-accent);
        color: var(--vd-accent);
      }
    </style>
  </body>
</html>
