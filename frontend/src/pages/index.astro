---
/**
 * Landing page ( / ) — front door for the v2 DEVELOPMENT instance
 * (v2.vibedeck.online). Per-deployment + gitignored (see .gitignore): this
 * file is specific to this box and must NOT be committed to the v2 branch.
 *
 * Layout: logo + VibeDeck hero, the tagline as a sub-heading, the
 * development-preview callout, the one-paragraph pitch, then "recently added"
 * and "upcoming" feature lists. Nothing else before the footer.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import ReticleMark from "../components/ReticleMark.astro";
import DeckModal from "../components/DeckModal.astro";
import { fetchDeck } from "../lib/api";

// Featured reference decks shown on the landing — each opens the shared deck
// modal when clicked. (Title comes from the deck so it stays accurate.)
const FEATURED: [string, string][] = [
  ["vibedeck", "what-is-vibedeck"],
  ["vibedeck", "anatomy-of-a-vibedeck-file"],
  ["vibedeck", "crafting-a-vibedeck-theme"],
];
const featured = (
  await Promise.all(
    FEATURED.map(async ([topic, slug]) => {
      const d = await fetchDeck(topic, slug);
      return d
        ? {
            topic,
            slug,
            title: d.title,
            url: d.url, // canonical (namespaced in the server edition)
            card_count: d.cards.length,
            created_at: null,
            updated_at: null,
          }
        : null;
    }),
  )
).filter((d): d is NonNullable<typeof d> => d !== null);

// Recently shipped on this v2 instance (newest first).
const recentlyAdded = [
  {
    label:
      "Your own corner of the site — every author gets a page and personal deck URLs (/u/you/…)",
    date: "Jun 9, 2026",
  },
  {
    label: "Pick your handle at sign-up; invite-gated accounts",
    date: "Jun 9, 2026",
  },
  {
    label:
      "Community safety: content moderation with human review, a Report button on every deck",
    date: "Jun 9, 2026",
  },
  {
    label: "Deck and theme builders — author cards and palettes with forms, no markdown needed",
    date: "Jun 7, 2026",
  },
  {
    label: "Public, unlisted, and private decks",
    date: "Jun 7, 2026",
  },
  {
    label: "Custom themes render for every reader, and decks can be embedded on other sites",
    date: "Jun 7, 2026",
  },
];

// Next up, from the v2 roadmap.
const upcoming = [
  "Keyword filtering on the deck index",
  "Search across decks",
  "Transition effects between cards",
  "Progressive reveal of bullet points",
  "Smarter moderation assistance",
];
---

<BaseLayout title="VibeDeck — development preview">
  <main class="landing">
    <!-- Hero: logo + wordmark, then the tagline as a sub-heading -->
    <section class="landing__hero">
      <ReticleMark class="landing__mark" size="clamp(3.5rem, 11vw, 5.5rem)" />
      <h1 class="landing__headline">VibeDeck</h1>
      <p class="landing__subhead">Knowledge, one card at a time.</p>
    </section>

    <!-- Development notice -->
    <aside class="devnotice" role="note">
      <span class="devnotice__tag">Development preview</span>
      <p class="devnotice__body">
        This is the <strong>v2 development instance</strong> of Vibedeck. It's a
        work in progress — features, content, and data here can change or break
        at any time, without warning. For the stable release, head to
        <a class="devnotice__link" href="https://vibedeck.online">vibedeck.online</a>.
      </p>
    </aside>

    <p class="landing__intro">
      Vibedeck turns your markdown files into beautiful, paginated card decks.
      Mobile-first. Distraction-free. Built for people who actually want to
      learn something.
    </p>

    <!-- Featured decks — click a thumbnail to open the deck modal -->
    {
      featured.length > 0 && (
        <section class="landing__section">
          <h2 class="landing__h2">Learn more about VibeDeck (using VibeDeck!)</h2>
          <ul class="featured">
            {featured.map((d) => (
              <li
                class="featured__item"
                role="button"
                tabindex="0"
                data-deck={JSON.stringify(d)}
                aria-label={`Open ${d.title}`}
              >
                <span class="featured__thumb">
                  <iframe
                    src={`${d.url}?embed=1`}
                    title={d.title}
                    loading="lazy"
                    scrolling="no"
                    tabindex="-1"
                    aria-hidden="true"
                  />
                </span>
                <h3 class="featured__title">{d.title}</h3>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <!-- Recently added -->
    <section class="landing__section">
      <h2 class="landing__h2">Recently added</h2>
      <ul class="flist">
        {
          recentlyAdded.map((item) => (
            <li class="flist__item">
              <span class="flist__label">{item.label}</span>
              <span class="flist__date">{item.date}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- Upcoming -->
    <section class="landing__section">
      <h2 class="landing__h2">Upcoming</h2>
      <ul class="flist">
        {upcoming.map((item) => <li class="flist__item">{item}</li>)}
      </ul>
    </section>

    <!-- Footer -->
    <footer class="landing__footer">
      <p class="landing__credit">
        Architectural decisions and editorial judgment by a human. Execution
        assisted by a very carefully guided code djinni.
      </p>
      <p>
        Built by
        <a class="link" href="https://conciergewebhost.ca" target="_blank" rel="noopener">
          Concierge Web Host</a> in a Starbucks in North Battleford,
        Saskatchewan.
      </p>
    </footer>
  </main>

  <DeckModal />

  <script>
    function whenReady(cb: () => void) {
      if ((window as any).Vibedeck) cb();
      else document.addEventListener("vibedeck:ready", cb, { once: true });
    }
    document.querySelectorAll<HTMLElement>(".featured__item[data-deck]").forEach((el) => {
      const open = () => {
        const deck = JSON.parse(el.getAttribute("data-deck") || "null");
        if (deck) whenReady(() => (window as any).Vibedeck.openDeck(deck));
      };
      el.addEventListener("click", open);
      el.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          open();
        }
      });
    });
  </script>
</BaseLayout>

<style>
  .landing {
    max-width: 46rem;
    margin: 0 auto;
    padding: clamp(2.5rem, 9vw, 6rem) 1.5rem;
  }

  /* ── Hero ── */
  .landing__mark {
    margin-bottom: 1.25rem;
  }
  .landing__headline {
    font-family: var(--vd-font-heading);
    font-size: clamp(2.75rem, 11vw, 5.5rem);
    line-height: 1.04;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--vd-heading);
    margin: 0;
  }
  .landing__subhead {
    font-family: var(--vd-font-heading);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: clamp(1.25rem, 4.5vw, 1.9rem);
    line-height: 1.1;
    color: var(--vd-accent);
    margin: 0.4rem 0 0;
  }

  /* ── Development notice ── */
  .devnotice {
    border: 1px solid var(--vd-accent);
    border-left-width: 4px;
    border-radius: var(--vd-radius);
    background: var(--vd-card-bg);
    padding: 1rem 1.25rem;
    margin: clamp(2rem, 6vw, 3rem) 0 0;
  }
  .devnotice__tag {
    display: inline-block;
    font-family: var(--vd-font-heading);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.75rem;
    color: var(--vd-bg);
    background: var(--vd-accent);
    padding: 0.2rem 0.6rem;
    border-radius: var(--vd-radius);
    margin-bottom: 0.6rem;
  }
  .devnotice__body {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--vd-text);
  }
  .devnotice__link {
    color: var(--vd-accent);
    text-decoration: underline;
  }

  /* ── Intro paragraph ── */
  .landing__intro {
    margin: clamp(2rem, 6vw, 3rem) 0 0;
    font-size: clamp(1.05rem, 3.2vw, 1.3rem);
    line-height: 1.6;
    color: var(--vd-text-muted);
    max-width: 40rem;
  }

  .link {
    color: var(--vd-accent);
    text-decoration: underline;
  }

  /* ── Feature sections ── */
  .landing__section {
    margin-top: clamp(2.5rem, 7vw, 4rem);
  }
  .landing__h2 {
    font-family: var(--vd-font-heading);
    font-size: clamp(1.6rem, 5vw, 2.25rem);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--vd-heading);
    margin: 0 0 1.25rem;
  }
  .landing__h2::before {
    content: "";
    display: block;
    width: 2.5rem;
    height: 2px;
    background: var(--vd-accent);
    margin-bottom: 1rem;
  }
  /* ── Featured decks ── */
  .featured {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr; /* one per row — stacked vertically */
  }
  .featured__item {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1rem;
    cursor: pointer;
  }
  .featured__item:focus-visible {
    outline: 2px solid var(--vd-accent);
    outline-offset: 4px;
    border-radius: var(--vd-radius);
  }
  .featured__thumb {
    flex: none;
    position: relative;
    width: clamp(8rem, 38%, 15rem);
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border: 1px solid var(--vd-card-border);
    border-radius: var(--vd-radius);
    background: var(--vd-bg);
  }
  .featured__item:hover .featured__thumb {
    border-color: var(--vd-accent);
  }
  .featured__thumb iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    pointer-events: none; /* clicks fall through to the item */
  }
  .featured__title {
    margin: 0;
    font-family: var(--vd-font-heading);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: 1.05rem;
    line-height: 1.15;
    color: var(--vd-heading);
  }
  .featured__item:hover .featured__title {
    color: var(--vd-accent);
  }

  .flist {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }
  .flist__item {
    position: relative;
    padding-left: 1.6rem;
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--vd-text);
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    align-items: baseline;
  }
  .flist__item::before {
    content: "›";
    position: absolute;
    left: 0;
    color: var(--vd-accent);
    font-family: var(--vd-font-heading);
  }
  .flist__date {
    flex: none;
    color: var(--vd-text-muted);
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  /* ── Footer ── */
  .landing__footer {
    margin-top: clamp(3.5rem, 9vw, 6rem);
    padding-top: 1.5rem;
    border-top: 1px solid var(--vd-card-border);
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--vd-text-muted);
  }
  .landing__credit {
    font-style: italic;
    margin: 0 0 0.75rem;
  }
  .landing__footer p {
    margin: 0 0 0.5rem;
  }
</style>
