---
/**
 * Landing page ( / ) — project intro for vibedeck.online.
 * Placeholder copy for now; links through to the deck library at /decks.
 * Uses the site default theme (operazione-stile).
 */
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Vibedeck — digital index cards">
  <main class="landing">
    <section class="landing__hero">
      <h1 class="landing__title">Vibedeck</h1>
      <p class="landing__tag">
        Digital index cards. Chunked knowledge, beautifully delivered.
      </p>
    </section>

    <section class="landing__body">
      <p>
        Vibedeck turns plain markdown into beautiful, mobile-first card decks —
        one focused idea per card, sequenced to build understanding without
        overwhelm.
      </p>
      <p>
        It isn't a slideshow. It's a reading experience: swipe through concept
        cards, summaries, quotes, and diagrams, each dressed by a theme that
        sets the mood.
      </p>
      <p>Open source, self-hostable, and authored entirely in markdown.</p>
    </section>

    <a class="landing__cta" href="/decks">Browse the sample decks →</a>

    <p class="landing__placeholder">
      Placeholder landing page — full content coming soon.
    </p>
  </main>
</BaseLayout>

<style>
  .landing {
    max-width: 44rem;
    margin: 0 auto;
    padding: clamp(2.5rem, 9vw, 6rem) 1.5rem;
  }
  .landing__title {
    font-family: var(--vd-font-heading);
    font-size: clamp(3rem, 13vw, 6rem);
    line-height: 1.05;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--vd-heading);
    margin: 0 0 0.5rem;
  }
  .landing__tag {
    color: var(--vd-text-muted);
    font-size: clamp(1.05rem, 3.5vw, 1.35rem);
    font-style: italic;
    margin: 0 0 2.5rem;
  }
  .landing__body {
    font-size: 1.0625rem;
    line-height: 1.7;
    max-width: 38rem;
  }
  .landing__body p {
    margin: 0 0 1.25rem;
  }
  .landing__cta {
    display: inline-block;
    margin-top: 1.5rem;
    padding: 0.7rem 1.4rem;
    font-family: var(--vd-font-heading);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--vd-text);
    text-decoration: none;
    border: 1px solid var(--vd-card-border);
    border-radius: var(--vd-radius);
    background: var(--vd-card-bg);
  }
  .landing__cta:hover {
    border-color: var(--vd-accent);
    color: var(--vd-accent);
  }
  .landing__placeholder {
    margin-top: 3rem;
    font-size: 0.8rem;
    color: var(--vd-text-muted);
    opacity: 0.7;
  }
</style>
