---
/**
 * Landing page ( / ) — front door for the v2 DEVELOPMENT instance
 * (v2.vibedeck.online). Per-deployment + gitignored (see .gitignore): this
 * file is specific to this box and must NOT be committed to the v2 branch.
 *
 * Layout: logo + VibeDeck hero, the tagline as a sub-heading, the
 * development-preview callout, the one-paragraph pitch, then "recently added"
 * and "upcoming" feature lists. Nothing else before the footer.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import ReticleMark from "../components/ReticleMark.astro";

// Recently shipped on this v2 instance (newest first).
const recentlyAdded = [
  {
    label: "Browse the library as deck cards with an expandable, full-screen viewer",
    date: "Jun 6, 2026",
  },
  {
    label: "Your account: create, edit, and delete your own decks",
    date: "Jun 6, 2026",
  },
  {
    label: "Sandbox — try the deck format with a live preview, nothing saved",
    date: "Jun 6, 2026",
  },
  {
    label: "Passwordless sign-in by magic link, with invite-gated signup",
    date: "Jun 6, 2026",
  },
  { label: "Sitewide navigation and a new logo", date: "Jun 6, 2026" },
];

// Next up, from the v2 roadmap.
const upcoming = [
  "Keyword filtering on the deck index",
  "Search across decks",
  "Public and private decks",
  "Custom theme upload",
  "Transition effects between cards",
  "Progressive reveal of bullet points",
];
---

<BaseLayout title="VibeDeck — development preview">
  <main class="landing">
    <!-- Hero: logo + wordmark, then the tagline as a sub-heading -->
    <section class="landing__hero">
      <ReticleMark class="landing__mark" size="clamp(3.5rem, 11vw, 5.5rem)" />
      <h1 class="landing__headline">VibeDeck</h1>
      <p class="landing__subhead">Knowledge, one card at a time.</p>
    </section>

    <!-- Development notice -->
    <aside class="devnotice" role="note">
      <span class="devnotice__tag">Development preview</span>
      <p class="devnotice__body">
        This is the <strong>v2 development instance</strong> of Vibedeck. It's a
        work in progress — features, content, and data here can change or break
        at any time, without warning. For the stable release, head to
        <a class="devnotice__link" href="https://vibedeck.online">vibedeck.online</a>.
      </p>
    </aside>

    <p class="landing__intro">
      Vibedeck turns your markdown files into beautiful, paginated card decks.
      Mobile-first. Distraction-free. Built for people who actually want to
      learn something.
    </p>

    <!-- Recently added -->
    <section class="landing__section">
      <h2 class="landing__h2">Recently added</h2>
      <ul class="flist">
        {
          recentlyAdded.map((item) => (
            <li class="flist__item">
              <span class="flist__label">{item.label}</span>
              <span class="flist__date">{item.date}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- Upcoming -->
    <section class="landing__section">
      <h2 class="landing__h2">Upcoming</h2>
      <ul class="flist">
        {upcoming.map((item) => <li class="flist__item">{item}</li>)}
      </ul>
    </section>

    <!-- Footer -->
    <footer class="landing__footer">
      <p class="landing__credit">
        Architectural decisions and editorial judgment by a human. Execution
        assisted by a very carefully guided code djinni.
      </p>
      <p>
        Built by
        <a class="link" href="https://conciergewebhost.ca" target="_blank" rel="noopener">
          Concierge Web Host</a> in a Starbucks in North Battleford,
        Saskatchewan.
      </p>
    </footer>
  </main>
</BaseLayout>

<style>
  .landing {
    max-width: 46rem;
    margin: 0 auto;
    padding: clamp(2.5rem, 9vw, 6rem) 1.5rem;
  }

  /* ── Hero ── */
  .landing__mark {
    margin-bottom: 1.25rem;
  }
  .landing__headline {
    font-family: var(--vd-font-heading);
    font-size: clamp(2.75rem, 11vw, 5.5rem);
    line-height: 1.04;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--vd-heading);
    margin: 0;
  }
  .landing__subhead {
    font-family: var(--vd-font-heading);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: clamp(1.25rem, 4.5vw, 1.9rem);
    line-height: 1.1;
    color: var(--vd-accent);
    margin: 0.4rem 0 0;
  }

  /* ── Development notice ── */
  .devnotice {
    border: 1px solid var(--vd-accent);
    border-left-width: 4px;
    border-radius: var(--vd-radius);
    background: var(--vd-card-bg);
    padding: 1rem 1.25rem;
    margin: clamp(2rem, 6vw, 3rem) 0 0;
  }
  .devnotice__tag {
    display: inline-block;
    font-family: var(--vd-font-heading);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.75rem;
    color: var(--vd-bg);
    background: var(--vd-accent);
    padding: 0.2rem 0.6rem;
    border-radius: var(--vd-radius);
    margin-bottom: 0.6rem;
  }
  .devnotice__body {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--vd-text);
  }
  .devnotice__link {
    color: var(--vd-accent);
    text-decoration: underline;
  }

  /* ── Intro paragraph ── */
  .landing__intro {
    margin: clamp(2rem, 6vw, 3rem) 0 0;
    font-size: clamp(1.05rem, 3.2vw, 1.3rem);
    line-height: 1.6;
    color: var(--vd-text-muted);
    max-width: 40rem;
  }

  .link {
    color: var(--vd-accent);
    text-decoration: underline;
  }

  /* ── Feature sections ── */
  .landing__section {
    margin-top: clamp(2.5rem, 7vw, 4rem);
  }
  .landing__h2 {
    font-family: var(--vd-font-heading);
    font-size: clamp(1.6rem, 5vw, 2.25rem);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--vd-heading);
    margin: 0 0 1.25rem;
  }
  .landing__h2::before {
    content: "";
    display: block;
    width: 2.5rem;
    height: 2px;
    background: var(--vd-accent);
    margin-bottom: 1rem;
  }
  .flist {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }
  .flist__item {
    position: relative;
    padding-left: 1.6rem;
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--vd-text);
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    align-items: baseline;
  }
  .flist__item::before {
    content: "›";
    position: absolute;
    left: 0;
    color: var(--vd-accent);
    font-family: var(--vd-font-heading);
  }
  .flist__date {
    flex: none;
    color: var(--vd-text-muted);
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  /* ── Footer ── */
  .landing__footer {
    margin-top: clamp(3.5rem, 9vw, 6rem);
    padding-top: 1.5rem;
    border-top: 1px solid var(--vd-card-border);
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--vd-text-muted);
  }
  .landing__credit {
    font-style: italic;
    margin: 0 0 0.75rem;
  }
  .landing__footer p {
    margin: 0 0 0.5rem;
  }
</style>
