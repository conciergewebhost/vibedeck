---
/**
 * Decks library ( /decks ) — all topics, grouped. (Previously the site root;
 * the root is now the landing page.)
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import { fetchTopics } from "../lib/api";

const topics = (await fetchTopics()) ?? [];
---

<BaseLayout title="Decks — Vibedeck">
  <main class="home">
    <a class="home__back" href="/">‹ Home</a>
    <header class="home__head">
      <h1 class="home__title">Decks</h1>
      <p class="home__tag">Browse the library, grouped by topic.</p>
    </header>

    {
      topics.length === 0 ? (
        <p class="home__empty">No topics yet.</p>
      ) : (
        <ul class="topic-list">
          {topics.map((t) => (
            <li class="topic-card">
              <a href={`/${t.slug}`}>
                <h2>{t.display_name}</h2>
                <p class="topic-card__count">
                  {t.deck_count} deck{t.deck_count === 1 ? "" : "s"}
                </p>
                {t.top_keywords.length > 0 && (
                  <ul class="kw">
                    {t.top_keywords.map((k) => (
                      <li>{k}</li>
                    ))}
                  </ul>
                )}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</BaseLayout>

<style>
  .home {
    max-width: 48rem;
    margin: 0 auto;
    padding: clamp(1.5rem, 6vw, 3.5rem) 1.5rem;
  }
  .home__back {
    color: var(--vd-text-muted);
    font-family: var(--vd-font-heading);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.85rem;
    text-decoration: none;
    display: inline-block;
    margin-bottom: 1.5rem;
  }
  .home__back:hover {
    color: var(--vd-accent);
  }
  .home__title {
    font-size: clamp(2.5rem, 10vw, 4.5rem);
    margin: 0 0 0.5rem;
    letter-spacing: -0.03em;
    background: linear-gradient(90deg, var(--vd-accent), var(--vd-accent-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .home__tag {
    color: var(--vd-text-muted);
    margin: 0 0 2.5rem;
  }
  .topic-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
  }
  .topic-card a {
    display: block;
    padding: 1.25rem;
    border: 1px solid var(--vd-card-border);
    border-radius: var(--vd-radius);
    background: var(--vd-card-bg);
    color: inherit;
    text-decoration: none;
  }
  .topic-card a:hover {
    border-color: var(--vd-accent);
  }
  .topic-card h2 {
    margin: 0 0 0.25rem;
  }
  .topic-card__count {
    color: var(--vd-text-muted);
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
  }
  .kw {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .kw li {
    font-size: 0.75rem;
    color: var(--vd-text-muted);
    border: 1px solid var(--vd-card-border);
    border-radius: 999px;
    padding: 0.15rem 0.6rem;
  }
</style>
