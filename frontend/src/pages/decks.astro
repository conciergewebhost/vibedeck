---
/**
 * Decks library ( /decks ) — every public deck as a thumbnail card, grouped
 * under its topic. Cards open the shared expandable modal (DeckModal); Edit
 * and Delete appear there only for decks the viewer owns.
 *
 * The section structure is server-rendered; the cards themselves are built on
 * the client by the shared component (so the card/modal behaviour is shared
 * verbatim with the portal). Deck data is embedded as a JSON island.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import DeckModal from "../components/DeckModal.astro";
import { fetchMeta, fetchPublicDecks } from "../lib/api";

// Full-content search (?q=…) happens in the API (card text is indexed
// server-side); the keyword filter (?kw=…) then narrows the fetched set.
const q = Astro.url.searchParams.get("q")?.trim() || null;
const allDecks = (await fetchPublicDecks(q ?? undefined)) ?? [];
const meta = await fetchMeta().catch(() => null);
// Per-user spaces: attribute each topic group to its author (two owners can
// have same-named topics, so the group key includes the owner).
const userSpaces = meta?.user_spaces_enabled ?? false;

// The keyword bar is built from the fetched (search-narrowed) set, so chips
// refine the current results; their links must carry ?q= through.
const kw = Astro.url.searchParams.get("kw");
const kwCounts = new Map<string, number>();
for (const d of allDecks)
  for (const k of d.keywords) kwCounts.set(k, (kwCounts.get(k) ?? 0) + 1);
const keywordBar = [...kwCounts.entries()].sort(
  (a, b) => b[1] - a[1] || a[0].localeCompare(b[0]),
);
const decks = kw ? allDecks.filter((d) => d.keywords.includes(kw)) : allDecks;

// Link helpers that preserve the active search.
const qPrefix = q ? `q=${encodeURIComponent(q)}&` : "";
const clearHref = q ? `/decks?q=${encodeURIComponent(q)}` : "/decks";

// Group decks by owner+topic, preserving the API's order.
type Group = {
  key: string;
  slug: string;
  name: string;
  owner: string | null;
  decks: typeof decks;
};
const groups: Group[] = [];
const byKey = new Map<string, number>();
for (const d of decks) {
  const key = `${d.owner_handle ?? ""}/${d.topic}`;
  if (!byKey.has(key)) {
    byKey.set(key, groups.length);
    groups.push({
      key,
      slug: d.topic,
      name: d.topic_name,
      owner: d.owner_handle,
      decks: [],
    });
  }
  groups[byKey.get(key)!].decks.push(d);
}

// `<` escaped so a deck title containing "</script>" can't break out.
const decksJson = JSON.stringify(groups).replace(/</g, "\\u003c");
---

<BaseLayout title="Decks — Vibedeck">
  <main class="decks">
    <header class="decks__head">
      <h1 class="decks__title">Decks</h1>
      <p class="decks__tag">Browse the library, grouped by topic.</p>
    </header>

    <form class="decks__search" method="get" action="/decks" role="search">
      <input
        class="decks__search-input"
        type="search"
        name="q"
        value={q ?? ""}
        placeholder="Search decks — titles, text, keywords…"
        aria-label="Search decks"
      />
      <button class="decks__search-btn" type="submit">Search</button>
    </form>

    {keywordBar.length > 0 && (
      <nav class="kwbar" aria-label="Filter by keyword">
        {keywordBar.map(([k, n]) => (
          <a
            class={k === kw ? "kw__link kw__link--active" : "kw__link"}
            href={k === kw ? clearHref : `/decks?${qPrefix}kw=${encodeURIComponent(k)}`}
          >
            {k} <span class="kw__count">{n}</span>
          </a>
        ))}
      </nav>
    )}
    {(q || kw) && (
      <p class="decks__filter">
        {decks.length} deck{decks.length === 1 ? "" : "s"}
        {q ? ` matching “${q}”` : ""}{q && kw ? "," : ""}{kw ? ` tagged “${kw}”` : ""} ·
        <a href={kw && q ? clearHref : "/decks"}>{kw && q ? "× clear keyword" : "× show all"}</a>
      </p>
    )}

    {
      groups.length === 0 ? (
        q || kw ? (
          <p class="decks__empty">
            No decks{q ? ` matching “${q}”` : ""}{kw ? ` tagged “${kw}”` : ""}.
            <a href="/decks">Show all decks</a>
          </p>
        ) : (
          <p class="decks__empty">No decks yet.</p>
        )
      ) : (
        groups.map((g) => (
          <section class="topic-group">
            <h2 class="topic-group__title">
              {g.name}
              {userSpaces && g.owner && (
                <a class="topic-group__owner" href={`/u/${g.owner}`}>
                  by @{g.owner}
                </a>
              )}
            </h2>
            <ul class="deckgrid" data-topic-grid={g.key} />
          </section>
        ))
      )
    }
  </main>

  <script type="application/json" id="decks-data" set:html={decksJson}></script>
  <DeckModal />
</BaseLayout>

<script>
  function whenReady(cb: () => void) {
    if ((window as any).Vibedeck) cb();
    else document.addEventListener("vibedeck:ready", cb, { once: true });
  }

  type Deck = {
    topic: string;
    slug: string;
    title: string;
    url: string;
    card_count: number;
    created_at: string | null;
    updated_at: string | null;
  };
  type Group = { key: string; slug: string; name: string; decks: Deck[] };

  const dataEl = document.getElementById("decks-data");
  const groups: Group[] = dataEl ? JSON.parse(dataEl.textContent || "[]") : [];

  whenReady(() => {
    const V = (window as any).Vibedeck;
    for (const g of groups) {
      const grid = document.querySelector<HTMLUListElement>(`[data-topic-grid="${g.key}"]`);
      if (!grid) continue;
      for (const d of g.decks) grid.append(V.buildCard(d));
    }
    // Deep-link: /decks?deck=<canonical url> opens that deck's modal on load
    // (used by the "View on vibedeck.online" link from an embed widget).
    // Legacy form <topic>/<slug> (pre-user-spaces embeds) still matches.
    const want = new URLSearchParams(location.search).get("deck");
    if (want) {
      const all = groups.flatMap((g) => g.decks);
      const target =
        all.find((d) => d.url === want) ??
        all.find((d) => `${d.topic}/${d.slug}` === want);
      if (target) V.openDeck(target);
    }
  });

  // When the owner deletes a deck from the modal, drop its card (and the topic
  // section if it's now empty). Cards are keyed by canonical url.
  document.addEventListener("vibedeck:deck-deleted", (e) => {
    const { url } = (e as CustomEvent).detail;
    const li = document.querySelector(`[data-deck-key="${url}"]`);
    const grid = li?.closest<HTMLElement>("[data-topic-grid]");
    li?.remove();
    if (grid && grid.children.length === 0) grid.closest(".topic-group")?.remove();
  });
</script>

<style>
  .decks {
    max-width: 52rem;
    margin: 0 auto;
    padding: clamp(1.5rem, 6vw, 3.5rem) 1.5rem;
  }
  .decks__title {
    font-size: clamp(2.5rem, 10vw, 4.5rem);
    margin: 0 0 0.5rem;
    letter-spacing: -0.03em;
    background: linear-gradient(90deg, var(--vd-accent), var(--vd-accent-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .decks__tag {
    color: var(--vd-text-muted);
    margin: 0 0 1.5rem;
  }
  .decks__search {
    display: flex;
    gap: 0.5rem;
    margin: 0 0 1rem;
  }
  .decks__search-input {
    flex: 1;
    max-width: 24rem;
    padding: 0.55rem 0.8rem;
    background: var(--vd-card-bg);
    border: 1px solid var(--vd-card-border);
    border-radius: var(--vd-radius);
    color: var(--vd-text);
    font: inherit;
  }
  .decks__search-btn {
    padding: 0.55rem 1rem;
    background: var(--vd-accent);
    border: 0;
    border-radius: var(--vd-radius);
    color: var(--vd-bg);
    font: inherit;
    font-weight: 600;
    cursor: pointer;
  }
  .decks__search-btn:hover {
    filter: brightness(1.08);
  }
  .kwbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0 0 1.5rem;
  }
  .kw__link {
    display: inline-block;
    font-size: 0.8rem;
    color: var(--vd-text-muted);
    border: 1px solid var(--vd-card-border);
    border-radius: 999px;
    padding: 0.2rem 0.7rem;
    text-decoration: none;
  }
  .kw__link:hover {
    border-color: var(--vd-accent);
    color: var(--vd-accent);
  }
  .kw__link--active {
    background: var(--vd-accent);
    border-color: var(--vd-accent);
    color: var(--vd-bg);
  }
  .kw__count {
    opacity: 0.7;
    font-size: 0.9em;
  }
  .decks__filter {
    color: var(--vd-text-muted);
    margin: 0 0 2rem;
  }
  .decks__filter a {
    color: var(--vd-accent);
    text-decoration: none;
    margin-left: 0.25rem;
  }
  .decks__empty {
    color: var(--vd-text-muted);
  }
  .topic-group {
    margin-bottom: clamp(2rem, 6vw, 3rem);
  }
  .topic-group__title {
    font-family: var(--vd-font-heading);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: clamp(1.3rem, 4vw, 1.8rem);
    color: var(--vd-heading);
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--vd-card-border);
  }
  .topic-group__owner {
    margin-left: 0.75rem;
    font-size: 0.8em;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    color: var(--vd-text-muted);
    text-decoration: none;
  }
  .topic-group__owner:hover {
    color: var(--vd-accent);
    text-decoration: underline;
  }
</style>
