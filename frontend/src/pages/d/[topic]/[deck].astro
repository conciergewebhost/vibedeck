---
/**
 * Flat deck landing page  ->  /d/{topic}/{deck-slug}
 * The deck's shareable address (mirrors the reader path under /d, like the
 * embed widget does under /embed). Canonical in the standalone edition; in
 * the server edition it 301s to /d/u/{handle}/… when the flat slugs resolve
 * unambiguously.
 *
 * A 404 from the public API still renders the page shell with a 404 status:
 * a signed-in owner is resolved client-side (private/in-review decks keep a
 * working landing page); everyone else sees "not found".
 */
import BaseLayout from "../../../layouts/BaseLayout.astro";
import DeckPage from "../../../components/DeckPage.astro";
import { fetchDeck, fetchMeta } from "../../../lib/api";

const { topic, deck } = Astro.params;
const data = await fetchDeck(topic!, deck!);

if (data) {
  const meta = await fetchMeta().catch(() => null);
  if (meta?.user_spaces_enabled && data.url) {
    return Astro.redirect("/d" + data.url, 301);
  }
} else {
  Astro.response.status = 404;
}
---

<BaseLayout title={data ? `${data.title} — Vibedeck` : "Deck — Vibedeck"}>
  {/* Unlisted decks are reachable by link but should stay out of search. */}
  {data && data.visibility !== "public" && (
    <meta name="robots" content="noindex" slot="head" />
  )}
  <DeckPage deck={data} readerUrl={`/${topic}/${deck}`} />
</BaseLayout>
