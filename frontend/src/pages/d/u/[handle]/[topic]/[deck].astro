---
/**
 * Namespaced deck landing page  ->  /d/u/{handle}/{topic}/{deck-slug}
 * The canonical deck address under per-user spaces (server edition);
 * identical to the flat landing page but resolved in the owner's namespace.
 *
 * A 404 from the public API still renders the page shell with a 404 status:
 * a signed-in owner is resolved client-side (private/in-review decks keep a
 * working landing page); everyone else sees "not found".
 */
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import DeckPage from "../../../../../components/DeckPage.astro";
import { fetchDeckByHandle } from "../../../../../lib/api";

const { handle, topic, deck } = Astro.params;
const data = await fetchDeckByHandle(handle!, topic!, deck!);

if (!data) {
  Astro.response.status = 404;
}
---

<BaseLayout title={data ? `${data.title} — Vibedeck` : "Deck — Vibedeck"}>
  {/* Unlisted decks are reachable by link but should stay out of search. */}
  {data && data.visibility !== "public" && (
    <meta name="robots" content="noindex" slot="head" />
  )}
  <DeckPage deck={data} readerUrl={`/u/${handle}/${topic}/${deck}`} />
</BaseLayout>
