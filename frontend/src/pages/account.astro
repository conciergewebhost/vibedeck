---
/**
 * /account — the logged-in user's deck portal.
 *
 * Session-gated client-side (redirects to /login without a session). Lists the
 * user's own decks as thumbnail cards via the shared DeckModal component; a
 * thumbnail opens the expandable viewer, the title links to the deck's landing
 * page (/d/…, with Edit/Delete). New decks are authored
 * in the builder/editor — or uploaded as .md files, re-enabled now that the
 * content/code inspection pipeline exists: uploads are read client-side and
 * submitted through the same validated portal endpoints, so every problem the
 * inspectors find (parse errors, unsafe markup, moderation blocks, quotas) is
 * reported back verbatim. Theme CSS upload likewise goes through
 * validate_theme_css. Flagged uploads show the in-review notice.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import DeckModal from "../components/DeckModal.astro";
---

<BaseLayout title="My decks — Vibedeck">
  <main class="portal">
    <header class="portal__head">
      <div>
        <h1 class="portal__title">My decks</h1>
        <p class="portal__email" data-email></p>
      </div>
      <div class="portal__actions">
        <a class="portal__btn" href="/account/build">+ New deck</a>
        <a class="portal__link" href="/account/edit">write markdown</a>
        <button class="portal__link" type="button" data-deck-upload-btn>upload .md</button>
        <input type="file" accept=".md,text/markdown" data-deck-upload hidden />
        <button class="portal__link" type="button" data-logout>Log out</button>
      </div>
    </header>

    <p class="portal__notice" data-notice hidden>
      Your deck was saved, but it's <strong>in review</strong>: an automatic
      check flagged it for a quick human look. It stays hidden from other
      readers until it's approved — no action needed on your side.
    </p>
    <p class="portal__err" data-upload-msg role="status" hidden></p>

    <ul class="deckgrid" data-deck-list></ul>

    <section class="portal__themes">
      <div class="portal__themes-head">
        <h2 class="portal__subhead">My themes</h2>
        <div class="portal__themes-actions">
          <button class="portal__link" type="button" data-theme-upload-btn>upload CSS</button>
          <input type="file" accept=".css,text/css" data-theme-upload hidden />
          <a class="portal__btn portal__btn--sm" href="/account/theme">+ New theme</a>
        </div>
      </div>
      <p class="portal__hint">
        Build a custom palette and type with the theme builder — or upload a
        <code>.css</code> file that defines <code>--vd-*</code> tokens (it's
        checked for safety on the way in). Use a theme by setting
        <code>theme: its-name</code> in a deck's frontmatter (or pick it in the
        deck builder). It renders for everyone who reads that deck.
      </p>
      <p class="portal__err" data-theme-msg role="status" hidden></p>
      <ul class="portal__theme-list" data-theme-list></ul>
    </section>
  </main>

  <DeckModal />
</BaseLayout>

<script>
  const SESSION_KEY = "vd_session";
  const $ = <T extends HTMLElement>(sel: string) => document.querySelector<T>(sel);

  const jwt = () => localStorage.getItem(SESSION_KEY);
  const authHeaders = () => ({ Authorization: `Bearer ${jwt()}` });

  function requireSession() {
    if (!jwt()) {
      location.replace("/login");
      throw new Error("no session");
    }
  }
  function logout() {
    localStorage.removeItem(SESSION_KEY);
    location.replace("/login");
  }
  function handle401() {
    localStorage.removeItem(SESSION_KEY);
    location.replace("/login");
  }
  function whenReady(cb: () => void) {
    if ((window as any).Vibedeck) cb();
    else document.addEventListener("vibedeck:ready", cb, { once: true });
  }
  async function loadMe() {
    const res = await fetch("/api/users/me", { headers: authHeaders() });
    if (res.status === 401) return handle401();
    const me = await res.json();
    const el = $<HTMLElement>("[data-email]");
    if (el) el.textContent = me.email ?? "";
  }

  async function loadDecks() {
    const res = await fetch("/api/decks/mine", { headers: authHeaders() });
    if (res.status === 401) return handle401();
    const decks = await res.json();
    const list = $<HTMLUListElement>("[data-deck-list]");
    if (!list) return;
    list.replaceChildren();
    if (decks.length === 0) {
      const li = document.createElement("li");
      li.className = "portal__empty";
      li.textContent = "You haven't created any decks yet. Start with “+ New deck”.";
      list.append(li);
      return;
    }
    const V = (window as any).Vibedeck;
    for (const d of decks) {
      const card = V.buildCard(d);
      // Quarantined decks stay listed for their owner, with a state badge.
      if (d.moderation_status === "flagged") {
        const badge = document.createElement("span");
        badge.className = "portal__review";
        badge.textContent = "In review";
        badge.title = "Hidden from readers until approved by a moderator.";
        card.append(badge);
        card.classList.add("portal__card--review");
      }
      list.append(card);
    }
  }

  async function loadThemes() {
    const res = await fetch("/api/themes/mine", { headers: authHeaders() });
    if (res.status === 401) return handle401();
    const themes = await res.json();
    renderThemes(themes);
  }

  function renderThemes(themes: { name: string; slug: string }[]) {
    const list = $<HTMLUListElement>("[data-theme-list]");
    if (!list) return;
    list.replaceChildren();
    // The section is always shown now (it hosts "+ New theme"); an empty list
    // gets a hint instead of hiding.
    if (themes.length === 0) {
      const li = document.createElement("li");
      li.className = "portal__empty";
      li.textContent = "No themes yet. Build one with “+ New theme”.";
      list.append(li);
      return;
    }
    for (const t of themes) {
      const li = document.createElement("li");
      li.className = "portal__theme";
      const label = document.createElement("span");
      label.className = "portal__theme-name";
      label.textContent = t.name;
      const slug = document.createElement("code");
      slug.className = "portal__theme-slug";
      slug.textContent = `theme: ${t.slug}`;
      const del = document.createElement("button");
      del.className = "portal__theme-del";
      del.type = "button";
      del.textContent = "Delete";
      del.addEventListener("click", () => deleteTheme(t));
      li.append(label, slug, del);
      list.append(li);
    }
  }

  async function deleteTheme(t: { name: string; slug: string }) {
    if (!confirm(`Delete theme “${t.name}”?`)) return;
    const res = await fetch(`/api/themes/mine/${encodeURIComponent(t.slug)}`, {
      method: "DELETE",
      headers: authHeaders(),
    });
    if (res.status === 401) return handle401();
    if (res.ok || res.status === 404) loadThemes();
  }

  // ── File uploads ────────────────────────────────────────────
  // Files are read in the browser and submitted through the same validated
  // portal endpoints as the editor/builder, so every inspection problem
  // (parse errors, unsafe markup, moderation blocks, quotas, conflicts)
  // comes back as a message we can show verbatim.

  function setMsg(sel: string, text: string | null) {
    const el = $<HTMLElement>(sel);
    if (!el) return;
    el.textContent = text ?? "";
    el.hidden = !text;
  }

  async function uploadDeckFile(file: File) {
    setMsg("[data-upload-msg]", `Checking ${file.name}…`);
    const markdown = await file.text();
    const res = await fetch("/api/decks/mine", {
      method: "POST",
      headers: { "Content-Type": "application/json", ...authHeaders() },
      body: JSON.stringify({ markdown }),
    });
    if (res.status === 401) return handle401();
    const data = await res.json().catch(() => ({}));
    if (!res.ok) {
      setMsg("[data-upload-msg]", `${file.name}: ${data.detail ?? `upload failed (${res.status})`}`);
      return;
    }
    setMsg("[data-upload-msg]", null);
    if (data.moderation_status === "flagged") {
      $("[data-notice]")?.removeAttribute("hidden");
    }
    loadDecks();
  }

  async function uploadThemeFile(file: File) {
    setMsg("[data-theme-msg]", `Checking ${file.name}…`);
    const css = await file.text();
    // Theme name from the filename; the backend slugs it for the
    // frontmatter `theme:` value.
    const name = file.name.replace(/\.css$/i, "").trim() || file.name;
    const res = await fetch("/api/themes", {
      method: "POST",
      headers: { "Content-Type": "application/json", ...authHeaders() },
      body: JSON.stringify({ name, css }),
    });
    if (res.status === 401) return handle401();
    const data = await res.json().catch(() => ({}));
    if (!res.ok) {
      const hint = res.status === 409 ? " Rename the file and try again." : "";
      setMsg("[data-theme-msg]", `${file.name}: ${data.detail ?? `upload failed (${res.status})`}${hint}`);
      return;
    }
    setMsg("[data-theme-msg]", null);
    loadThemes();
  }

  function wireUpload(btnSel: string, inputSel: string, handler: (f: File) => void) {
    const input = $<HTMLInputElement>(inputSel);
    $(btnSel)?.addEventListener("click", () => input?.click());
    input?.addEventListener("change", () => {
      const file = input.files?.[0];
      if (file) handler(file);
      input.value = ""; // allow re-selecting the same file after a fix
    });
  }

  function initPortal() {
    requireSession();
    $("[data-logout]")?.addEventListener("click", logout);

    // The editor/builder land here with ?flagged=1 when a save was quarantined.
    if (new URLSearchParams(location.search).get("flagged")) {
      $("[data-notice]")?.removeAttribute("hidden");
      history.replaceState(null, "", "/account");
    }

    wireUpload("[data-deck-upload-btn]", "[data-deck-upload]", uploadDeckFile);
    wireUpload("[data-theme-upload-btn]", "[data-theme-upload]", uploadThemeFile);

    loadMe();
    loadThemes();
    whenReady(loadDecks);
  }

  initPortal();
</script>

<style>
  .portal {
    max-width: 52rem;
    margin: 0 auto;
    padding: clamp(1.5rem, 6vw, 3rem) 1.5rem;
  }
  .portal__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .portal__title {
    margin: 0;
  }
  .portal__email {
    margin: 0.25rem 0 0;
    color: var(--vd-text-muted);
    font-size: 0.9rem;
  }
  .portal__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .portal__btn {
    padding: 0.55rem 1.1rem;
    background: var(--vd-accent);
    border: 1px solid var(--vd-accent);
    border-radius: var(--vd-radius);
    color: var(--vd-bg);
    font: inherit;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
  }
  .portal__btn:hover {
    filter: brightness(1.08);
  }
  .portal__link {
    background: none;
    border: 0;
    color: var(--vd-text-muted);
    cursor: pointer;
    font: inherit;
    text-decoration: underline;
  }
  .portal__empty {
    color: var(--vd-text-muted);
  }
  .portal__notice {
    margin: 0 0 1.25rem;
    padding: 0.75rem 1rem;
    background: var(--vd-card-bg);
    border: 1px solid #fbbf24;
    border-radius: var(--vd-radius);
    color: var(--vd-text);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .portal__err {
    margin: 0 0 1.25rem;
    color: #f87171;
    font-size: 0.9rem;
    line-height: 1.5;
    word-break: break-word;
  }
  .portal__themes-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .portal__card--review {
    position: relative;
    opacity: 0.85;
  }
  .portal__review {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.1rem 0.5rem;
    background: #fbbf24;
    border-radius: 999px;
    color: #1a1a1a;
    font-size: 0.7rem;
    font-weight: 700;
    pointer-events: none;
  }

  /* ── Themes ── */
  .portal__themes {
    margin-top: clamp(2rem, 6vw, 3rem);
    border-top: 1px solid var(--vd-card-border);
    padding-top: 1.5rem;
  }
  .portal__themes-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.4rem;
  }
  .portal__subhead {
    margin: 0;
    font-size: 1.2rem;
  }
  .portal__btn--sm {
    padding: 0.4rem 0.85rem;
    font-size: 0.9rem;
  }
  .portal__hint {
    margin: 0 0 1rem;
    color: var(--vd-text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .portal__theme-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }
  .portal__theme {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 0.9rem;
    background: var(--vd-card-bg);
    border: 1px solid var(--vd-card-border);
    border-radius: var(--vd-radius);
  }
  .portal__theme-name {
    font-weight: 600;
    color: var(--vd-text);
  }
  .portal__theme-slug {
    color: var(--vd-text-muted);
    font-size: 0.8rem;
  }
  .portal__theme-del {
    margin-left: auto;
    padding: 0.35rem 0.75rem;
    background: transparent;
    border: 1px solid var(--vd-card-border);
    border-radius: var(--vd-radius);
    color: #f87171;
    cursor: pointer;
    font: inherit;
    font-size: 0.85rem;
  }
  .portal__theme-del:hover {
    border-color: #f87171;
  }
</style>
