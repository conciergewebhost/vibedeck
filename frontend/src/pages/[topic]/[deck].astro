---
/**
 * Deck card-view page  ->  /{topic}/{deck-slug}
 * The reader: paginated card view with full navigation. Applies the deck's
 * theme. Card content is re-parsed from the canonical file by the backend.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Reader from "../../components/Reader.astro";
import { fetchDeck } from "../../lib/api";

const { topic, deck } = Astro.params;
const data = await fetchDeck(topic!, deck!);

if (!data) {
  return Astro.rewrite("/404");
}

// ?embed=1 → a chrome-less first-slide view, used as the portal thumbnail.
const embed = Astro.url.searchParams.has("embed");

// Built-in themes resolve to bundled stylesheets at build time. Any other
// theme name is a user's private theme: BaseLayout falls back to default for
// SSR, and we inject the owner's CSS client-side (below) if they're signed in.
const BUILTIN_THEMES = new Set(["default", "operazione-stile", "fascicolo"]);
const customTheme = BUILTIN_THEMES.has(data.theme) ? null : data.theme;
---

<BaseLayout title={`${data.title} — Vibedeck`} theme={data.theme} showNav={false}>
  <Reader deck={data} topicSlug={topic!} embed={embed} />

  {
    customTheme && (
      <script is:inline define:vars={{ slug: customTheme }}>
        {/* Private theme: fetch the owner's CSS (auth-scoped) and inject it.
            Anonymous/non-owner viewers get no session token → default theme.
            Runs in the standalone reader and inside the portal's modal iframe. */}
        (() => {
          try {
            const jwt = localStorage.getItem("vd_session");
            if (!jwt) return;
            fetch("/api/themes/mine/" + encodeURIComponent(slug) + ".css", {
              headers: { Authorization: "Bearer " + jwt },
            })
              .then((r) => (r.ok ? r.text() : null))
              .then((css) => {
                if (!css) return;
                const s = document.getElementById("vd-custom-theme") || document.createElement("style");
                s.id = "vd-custom-theme";
                s.textContent = css;
                document.head.appendChild(s);
              })
              .catch(() => {});
          } catch (e) {}
        })();
      </script>
    )
  }
</BaseLayout>
