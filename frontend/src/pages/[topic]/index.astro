---
/**
 * Flat topic deck-index page  ->  /{topic}
 * Canonical in the standalone edition. In the server edition it 301s to the
 * topic's /u/{handle}/{topic} home when the slug is unambiguous, else 404s.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import { fetchMeta, fetchTopic } from "../../lib/api";

const { topic } = Astro.params;
const data = await fetchTopic(topic!);

if (!data) {
  return Astro.rewrite("/404");
}

const meta = await fetchMeta().catch(() => null);
if (meta?.user_spaces_enabled && data.url) {
  // Preserve the query string so /{topic}?kw=… filters after the redirect.
  return Astro.redirect(data.url + Astro.url.search, 301);
}

// Single-keyword filter: /{topic}?kw={keyword}. Chips are links; the active
// chip links back to the bare path (click again to clear).
const kw = Astro.url.searchParams.get("kw");
const decks = kw ? data.decks.filter((d) => d.keywords.includes(kw)) : data.decks;
const basePath = Astro.url.pathname;
---

<BaseLayout title={`${data.display_name} — Vibedeck`} theme={data.theme ?? undefined}>
  <main class="topic">
    <a class="topic__back" href="/decks">‹ All decks</a>
    <h1>{data.display_name}</h1>
    {data.description && <p class="topic__desc">{data.description}</p>}
    {kw && (
      <p class="topic__filter">
        {decks.length} deck{decks.length === 1 ? "" : "s"} tagged “{kw}” ·
        <a href={basePath}>× show all</a>
      </p>
    )}

    {
      decks.length === 0 ? (
        kw ? (
          <p>No decks tagged “{kw}”. <a href={basePath}>Show all decks</a></p>
        ) : (
          <p>No decks in this topic yet.</p>
        )
      ) : (
        <ul class="deck-list">
          {decks.map((d) => (
            <li class="deck-card">
              {/* Cards link to the deck's landing page; the reader is one
                  click further (“Read deck”). */}
              <a href={`/d${d.url}`}>
                <h2>{d.title}</h2>
                {d.description && <p class="deck-card__desc">{d.description}</p>}
                <p class="deck-card__meta">
                  {d.author} · {d.card_count} card{d.card_count === 1 ? "" : "s"}
                </p>
              </a>
              {d.keywords.length > 0 && (
                <ul class="kw">
                  {d.keywords.map((k) => (
                    <li>
                      <a
                        class={k === kw ? "kw__link kw__link--active" : "kw__link"}
                        href={k === kw ? basePath : `${basePath}?kw=${encodeURIComponent(k)}`}
                      >
                        {k}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>
      )
    }
  </main>
</BaseLayout>

<style>
  .topic {
    max-width: 48rem;
    margin: 0 auto;
    padding: clamp(1.5rem, 6vw, 3.5rem) 1.5rem;
  }
  .topic__back {
    color: var(--vd-text-muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 1.5rem;
  }
  .topic__desc {
    color: var(--vd-text-muted);
    margin: 0 0 2rem;
  }
  .topic__filter {
    color: var(--vd-text-muted);
    margin: -1rem 0 1.5rem;
  }
  .topic__filter a {
    color: var(--vd-accent);
    text-decoration: none;
    margin-left: 0.25rem;
  }
  .deck-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }
  /* The card box wraps the link AND the keyword chips (chips are their own
     links now — anchors can't nest). */
  .deck-card {
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--vd-card-border);
    border-radius: var(--vd-radius);
    background: var(--vd-card-bg);
  }
  .deck-card:hover {
    border-color: var(--vd-accent);
  }
  .deck-card > a {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .deck-card h2 {
    margin: 0 0 0.4rem;
  }
  .deck-card__desc {
    margin: 0 0 0.6rem;
  }
  .deck-card__meta {
    color: var(--vd-text-muted);
    font-size: 0.85rem;
    margin: 0 0 0.75rem;
  }
  .kw {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .kw__link {
    display: inline-block;
    font-size: 0.75rem;
    color: var(--vd-text-muted);
    border: 1px solid var(--vd-card-border);
    border-radius: 999px;
    padding: 0.15rem 0.6rem;
    text-decoration: none;
  }
  .kw__link:hover {
    border-color: var(--vd-accent);
    color: var(--vd-accent);
  }
  .kw__link--active {
    background: var(--vd-accent);
    border-color: var(--vd-accent);
    color: var(--vd-bg);
  }
</style>
