# Frontend (Astro SSR) environment template. Copy to .env.
# Base URL of the FastAPI backend the SSR pages fetch from.
API_BASE_URL=http://localhost:8000

# Public site URL (this deployment). When set, pages emit absolute canonical
# and Open Graph / Twitter image URLs; leave unset for relative URLs.
PUBLIC_SITE_URL=https://your-instance.example

# Optional sitewide analytics (e.g. a self-hosted Umami): when BOTH are set,
# every page's <head> loads the script with data-website-id. The website id
# is not a secret (it ships in the HTML); these live here so deployments can
# differ without touching tracked code. Leave unset for no analytics.
# PUBLIC_ANALYTICS_SRC=https://analytics.example.com/script.js
# PUBLIC_ANALYTICS_WEBSITE_ID=00000000-0000-0000-0000-000000000000
