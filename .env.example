# ── Vibedeck environment template ─────────────────────────────
# Copy to .env and populate. Never commit .env.

# PostgreSQL connection string (SQLAlchemy / asyncpg-style sync URL).
# Format: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+psycopg://vibedeck:changeme@localhost:5432/vibedeck

# JWT signing secret. Generate with: openssl rand -hex 32
SECRET_KEY=replace-me-with-a-32-byte-hex-secret

# Absolute path to deck file storage (the canonical source of truth).
# Set this to the absolute path of this repo's decks/ directory.
# The DB only indexes metadata parsed from these files.
UPLOAD_DIR=/absolute/path/to/vibedeck/decks

# Public URL of this instance (used for links, CORS, SEO).
# Local dev: http://localhost:4321 — production: your public https URL.
BASE_URL=http://localhost:4321

# development | production
ENVIRONMENT=development

# Which edition this deployment runs as: standalone | server
#   standalone — a single person on their own server (no public sign-up).
#   server     — a host running many users' decks (invite-gated sign-up).
# Defaults to standalone. A multi-user host must set this to `server`.
EDITION=standalone

# Shared token for the /admin web upload surface. Generate with:
#   openssl rand -hex 32
UPLOAD_TOKEN=replace-me-with-a-long-random-token

# Account that token-gated (and CLI) uploads are attributed to.
UPLOAD_OWNER_EMAIL=owner@example.com

# ── Passwordless (magic-link) auth ────────────────────────────
# Shared invite code that gates NEW account creation. This is the SEED /
# fallback value: the owner can change the code — or switch the requirement
# off entirely — at runtime from the admin Settings tab (stored in the
# site_settings table). Generate with: openssl rand -hex 16
NEW_USER_CODE=replace-me-with-an-invite-code

# Resend (https://resend.com) HTTP API — used to email magic links.
# The from-address domain must be verified in your Resend account.
RESEND_API_KEY=re_replace_me
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_FROM_NAME=Vibedeck

# Per-IP rate limits on the magic-link request endpoint (sliding 1-hour
# window). Optional — these are the defaults. The overall cap blunts
# email-spam/hammering; the bad-code cap throttles invite-code guessing.
# RATE_LIMIT_REQUESTS_PER_HOUR=12
# RATE_LIMIT_BAD_CODE_PER_HOUR=5

# ── Content moderation (server edition) ───────────────────────
# Recipient of the daily moderation digest (review-queue size + last-24h
# block/flag/report counts). Optional — defaults to UPLOAD_OWNER_EMAIL.
# ADMIN_DIGEST_EMAIL=admin@example.com

# ── Quotas + abuse controls ───────────────────────────────────
# Per-user creation caps (server edition only; admins and the owner are
# exempt). Optional — these are the defaults.
# QUOTA_MAX_DECKS=50
# QUOTA_MAX_THEMES=20
# A deck reported by this many DISTINCT readers auto-quarantines into the
# admin review queue; reports are rate-limited per IP.
# REPORT_QUARANTINE_THRESHOLD=3
# RATE_LIMIT_REPORTS_PER_HOUR=5
