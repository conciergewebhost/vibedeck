# ── Vibedeck environment template ─────────────────────────────
# Copy to .env and populate. Never commit .env.

# PostgreSQL connection string (SQLAlchemy / asyncpg-style sync URL).
# Format: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+psycopg://vibedeck:changeme@localhost:5432/vibedeck

# JWT signing secret. Generate with: openssl rand -hex 32
SECRET_KEY=replace-me-with-a-32-byte-hex-secret

# Absolute path to deck file storage (the canonical source of truth).
# Set this to the absolute path of this repo's decks/ directory.
# The DB only indexes metadata parsed from these files.
UPLOAD_DIR=/absolute/path/to/vibedeck/decks

# Public URL of this instance (used for links, CORS, SEO).
# Local dev: http://localhost:4321 — production: your public https URL.
BASE_URL=http://localhost:4321

# development | production
ENVIRONMENT=development

# Shared token for the /admin web upload surface. Generate with:
#   openssl rand -hex 32
UPLOAD_TOKEN=replace-me-with-a-long-random-token

# Account that token-gated (and CLI) uploads are attributed to.
UPLOAD_OWNER_EMAIL=owner@example.com
