# ── Environment ───────────────────────────────────────────────
.env
*.local

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/

# ── Node / Astro ──────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.astro/
npm-debug.log*

# ── Uploaded deck files ───────────────────────────────────────
# Decks are user content, not code: ignore everything under decks/
# except the sample fixtures + reference decks that ship with the repo.
decks/*.md
!decks/vibedeck__what-is-vibedeck.md
!decks/tradecraft-primer.md
!decks/vibedeck__anatomy-of-a-vibedeck-file.md
!decks/vibedeck__crafting-a-vibedeck-theme.md

# ── Local, box-specific docs (never committed) ────────────────
# Operational notes + private, box-only strategy notes; kept on the box only.
HANDOFF.md
EDITIONS-COMMERCIAL.md

# ── Optional private add-on layer (kept out of this repo) ──────
# A `private` package the backend loads if present (see main.py); open-core
# deployments run without it.
backend/private/

# ── Claude Code local settings ────────────────────────────────
.claude/settings.local.json

# ── OS / editor ───────────────────────────────────────────────
.DS_Store
*.swp
.idea/
.vscode/
