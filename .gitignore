# ── Environment ───────────────────────────────────────────────
.env
*.local

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/

# ── Node / Astro ──────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.astro/
npm-debug.log*

# ── Uploaded deck files ───────────────────────────────────────
# decks/ is LIVE user content (the UPLOAD_DIR), never code. The reference
# decks that ship with the repo live in samples/ instead; seed.py copies
# them into a fresh instance's UPLOAD_DIR.
decks/

# The landing page is per-deployment (astro.config.mjs falls back to a
# "/" -> /decks redirect when no local index.astro exists).
frontend/src/pages/index.astro

# ── Local, box-specific docs (never committed) ────────────────
# Operational notes + private, box-only strategy notes; kept on the box only.
HANDOFF.md
EDITIONS-COMMERCIAL.md

# ── Optional private add-on layer (kept out of this repo) ──────
# A `private` package the backend loads if present (see main.py); open-core
# deployments run without it.
backend/private/

# ── Claude Code local settings ────────────────────────────────
.claude/settings.local.json

# ── OS / editor ───────────────────────────────────────────────
.DS_Store
*.swp
.idea/
.vscode/
