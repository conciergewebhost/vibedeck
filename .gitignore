# ── Environment ───────────────────────────────────────────────
.env
*.local

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/

# ── Node / Astro ──────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.astro/
npm-debug.log*

# ── Per-deployment landing page ───────────────────────────────
# The site root ("/") is a per-deployment concern, not part of the
# platform. Drop in a src/pages/index.astro for your own landing page;
# without one, astro.config redirects "/" to the deck library at /decks.
frontend/src/pages/index.astro

# ── Uploaded deck files ───────────────────────────────────────
# Decks are user content, not code: ignore everything under decks/
# except the sample fixture that ships with the repo.
decks/*.md
!decks/vibedeck__what-is-vibedeck.md
!decks/tradecraft-primer.md

# ── Claude Code local settings ────────────────────────────────
.claude/settings.local.json

# ── OS / editor ───────────────────────────────────────────────
.DS_Store
*.swp
.idea/
.vscode/
